PORT=8000
PROSODY_DATA_DIR=.prosody-data
SMALLWEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
WEB_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SESSION_IDLE_TIMEOUT_SECS=90
ASR_STALL_TIMEOUT_SECS=4
LLM_TIMEOUT_SECS=8
TTS_TIMEOUT_SECS=6
TRANSPORT_DISCONNECT_GRACE_SECS=20
AUDIO_INPUT_SAMPLE_RATE=16000
AUDIO_OUTPUT_SAMPLE_RATE=24000

# Future runtime selection
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-nano
LLM_SYSTEM_PROMPT=You are Prosody, a concise realtime interview and presentation coach.

# Required for local realtime sessions
OPENAI_API_KEY=your-openai-api-key
DEEPGRAM_API_KEY=your-deepgram-key
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id

# Optional / future deployed transport
DAILY_API_KEY=your-daily-key

# Required for authenticated browser + agent flow
# Summary/flashcard generation also assumes the agent is running against the Supabase-backed store.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Optional in current agent runtime; browser uses VITE_SUPABASE_ANON_KEY
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:5432/prosody

# Future auth/deployment settings
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
